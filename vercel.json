{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "version": 2,
    "cleanUrls": true,
    "regions": ["sin1"],
    "rewrites": [{
        "source": "/(.*)",
        "destination": "/index.html"
    }],
    "headers": [{
        "source": "/sw.js",
        "headers": [{
                "key": "Cache-Control",
                "value": "no-cache"
            },
            {
                "key": "Service-Worker-Allowed",
                "value": "/"
            }
        ]
    }]
}